# Supabase (Postgres) connection settings for JDBC
#
# Where to find these:
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> "URI"
# Then split into host / db / user / password.

SUPABASE_DB_HOST=your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_db_password

# Supabase typically requires SSL
SUPABASE_DB_SSLMODE=require

# Backward-compatible alias (either key works in code)
SUPABASE_DB_SSL_MODE=require
